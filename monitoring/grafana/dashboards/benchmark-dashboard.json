    {
      "type": "table",
      "title": "All Benchmark Results",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 39 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [{ "id": "displayName", "value": "P50 (µs)" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [{ "id": "displayName", "value": "P90 (µs)" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [{ "id": "displayName", "value": "P99 (µs)" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #D" },
            "properties": [{ "id": "displayName", "value": "P99.9 (µs)" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #E" },
            "properties": [{ "id": "displayName", "value": "Avg (µs)" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #F" },
            "properties": [{ "id": "displayName", "value": "Achieved (msgs/s)" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #G" },
            "properties": [{ "id": "displayName", "value": "Target (msgs/s)" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "benchmark": 0,
              "mode": 1,
              "target_rate": 2
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },

{
  "uid": "exposure-benchmark",
  "title": "Exposure Engine — Benchmark Dashboard",
  "tags": ["benchmark", "exposure-engine"],
  "timezone": "browser",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "row",
      "title": "In-Process Benchmark (Engine)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1
    },
    {
      "type": "barchart",
      "title": "Engine — Latency Percentiles (µs)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "µs",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1,
            "axisBorderShow": false,
            "axisPlacement": "auto",
            "scaleDistribution": { "type": "linear" },
            "gradientMode": "scheme"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "xTickLabelRotation": -45
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "benchmark_latency_p50_microseconds{benchmark=\"engine\"}",
          "legendFormat": "p50 · {{mode}} · {{target_rate}}/s",
          "instant": true,
          "range": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "benchmark_latency_p90_microseconds{benchmark=\"engine\"}",
          "legendFormat": "p90 · {{mode}} · {{target_rate}}/s",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "benchmark_latency_p99_microseconds{benchmark=\"engine\"}",
          "legendFormat": "p99 · {{mode}} · {{target_rate}}/s",
          "instant": true,
          "range": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "benchmark_latency_p999_microseconds{benchmark=\"engine\"}",
          "legendFormat": "p99.9 · {{mode}} · {{target_rate}}/s",
          "instant": true,
          "range": false,
          "refId": "D"
        }
      ]
    },
    {
